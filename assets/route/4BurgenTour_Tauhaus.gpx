      <trkpt lat="50.0250" lon="13.5860"><ele>445</ele></trkpt>
      <trkpt lat="50.0242" lon="13.5868"><ele>428</ele></trkpt>
      <trkpt lat="50.0235" lon="13.5872"><ele>415</ele></trkpt>
      <trkpt lat="50.0225" lon="13.5878"><ele>405</ele></trkpt>
      <trkpt lat="50.0215" lon="13.5883"><ele>397</ele></trkpt>
      <trkpt lat="50.0205" lon="13.5888"><ele>393</ele></trkpt>
