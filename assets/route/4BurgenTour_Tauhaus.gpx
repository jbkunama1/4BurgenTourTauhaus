      <trkpt lat="50.0222" lon="13.5850"><ele>382</ele></trkpt>
      <trkpt lat="50.0228" lon="13.5842"><ele>383</ele></trkpt>
      <trkpt lat="50.0235" lon="13.5833"><ele>390</ele></trkpt>
      <trkpt lat="50.0240" lon="13.5830"><ele>395</ele></trkpt>
